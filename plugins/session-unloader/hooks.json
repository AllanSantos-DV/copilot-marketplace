{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node boot.mjs",
        "timeout": 20
      },
      {
        "type": "command",
        "command": "node scan-hook.mjs session-start",
        "timeout": 20
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "node scan-hook.mjs user-prompt",
        "timeout": 20
      }
    ]
  }
}
